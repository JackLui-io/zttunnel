<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scsdky.web.mapper.TunnelNameMapper">

    <resultMap id="BaseResultMap" type="com.scsdky.web.domain.TunnelName">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="tunnelName" column="tunnel_name" jdbcType="VARCHAR"/>
        <result property="parentId" column="parent_id" jdbcType="BIGINT"/>
        <result property="status" column="status" jdbcType="BOOLEAN"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="mileage" column="mileage" jdbcType="DOUBLE"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,tunnel_name,parent_id,
        status,create_time,update_time,mileage
    </sql>
    <select id="getTunnelName" resultType="com.scsdky.web.domain.TunnelName">
        select
        <include refid="Base_Column_List"/>
        from t_tunnel_name a
        where exists (select 1 from t_user_tunnel b where a.id = b.tunnel_name_id and b.user_id = #{userId})

    </select>
</mapper>
